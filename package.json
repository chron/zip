{
  "name": "zip",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,convex -c blue,magenta \"vite\" \"convex dev\"",
    "dev:vite": "vite",
    "dev:convex": "convex dev",
    "tsc": "tsc -b",
    "typecheck": "bun run tsc",
    "lint": "oxlint .",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run typecheck && bun run lint && bun run knip && bun run test",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "seed": "bun run scripts/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "knip": "^6.4.1",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-router": "^1.168.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.35.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
